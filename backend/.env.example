# Servidor
NODE_ENV=development
PORT=3333

# Banco de dados (usado pelo Prisma)
# Host "postgres" é o nome do serviço no docker-compose.
# Para rodar o backend fora do Docker, troque para localhost.
DATABASE_URL=postgresql://medsync:medsync@postgres:5432/medsync?schema=public

# JWT
JWT_SECRET=troque-este-valor-em-producao
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:3000
