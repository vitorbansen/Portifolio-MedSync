generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PACIENTE
  MEDICO
  ADMINISTRADOR
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  CANCELADO
  REALIZADO
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senhaHash  String   @map("senha_hash")
  role       Role     @default(PACIENTE)
  criadoEm   DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  medico   Medico?
  paciente Paciente?

  @@map("usuarios")
}

model Medico {
  id              String   @id @default(uuid())
  usuarioId       String   @unique @map("usuario_id")
  especialidade   String
  crm             String   @unique
  horariosAtendimento Json?  @map("horarios_atendimento")

  usuario      Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]

  @@map("medicos")
}

model Paciente {
  id             String    @id @default(uuid())
  usuarioId      String?   @unique @map("usuario_id")
  nome           String
  telefone       String
  dataNascimento DateTime? @map("data_nascimento")

  usuario      Usuario?       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]

  @@index([telefone])
  @@map("pacientes")
}

model Agendamento {
  id             String            @id @default(uuid())
  pacienteId     String            @map("paciente_id")
  medicoId       String            @map("medico_id")
  periodoInicio  DateTime          @map("periodo_inicio")
  periodoFim     DateTime          @map("periodo_fim")
  status         StatusAgendamento @default(AGENDADO)
  criadoEm       DateTime          @default(now()) @map("criado_em")

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  medico   Medico   @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  // Unicidade por (medicoId, periodoInicio) só em agendamentos ATIVOS — implementada
  // como índice parcial em SQL (ver migration partial_unique_agendamento_ativo),
  // já que Prisma não suporta índice único parcial de forma declarativa.
  @@index([pacienteId])
  @@index([medicoId, periodoInicio])
  @@map("agendamentos")
}
